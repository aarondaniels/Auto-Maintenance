# Local dev: points at the docker-compose Postgres below.
# In Azure: set this to your Azure Database for PostgreSQL connection string.
DATABASE_URL=postgresql+psycopg://amt:amt@localhost:5432/amt

# Generate a real secret for anything beyond local dev, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
